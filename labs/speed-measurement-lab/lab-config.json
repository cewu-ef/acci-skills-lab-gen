{
  "id": "speed-measurement-lab",
  "title": "Laboratory Measurements of Speed",
  "subtitle": "BOX 1.1 · Interactive lab",
  "layout": "standard",
  "equipment": "kinematics",
  "canvas": { "w": 1000, "h": 470 },

  "controls": [
    {
      "id": "method",
      "label": "Method",
      "width": 300,
      "value": "two",
      "options": [
        { "value": "two",    "label": "Two light gates (Figure 1.3)" },
        { "value": "one",    "label": "One light gate (Figure 1.4)" },
        { "value": "ticker", "label": "Ticker-timer (Figure 1.5)" }
      ]
    },
    {
      "id": "motion",
      "label": "Motion",
      "width": 210,
      "value": "constant",
      "options": [
        { "value": "constant", "label": "Constant speed" },
        { "value": "accel",    "label": "Accelerating" }
      ]
    }
  ],

  "params": [
    { "id": "v0", "label": "Starting speed", "min": 0.2, "max": 1.2, "step": 0.05, "value": 0.5,
      "unit": "m/s", "decimals": 2 },
    { "id": "accel", "label": "Acceleration", "min": 0.1, "max": 0.8, "step": 0.05, "value": 0.3,
      "unit": "m/s²", "decimals": 2, "showIf": { "control": "motion", "in": ["accel"] } },
    { "id": "d", "label": "Distance between gates", "min": 0.3, "max": 1.4, "step": 0.05, "value": 0.8,
      "unit": "m", "decimals": 2, "showIf": { "control": "method", "in": ["two"] } },
    { "id": "cardL", "label": "Card length", "min": 0.05, "max": 0.25, "step": 0.01, "value": 0.1,
      "unit": "m", "decimals": 2, "showIf": { "control": "method", "in": ["two", "one"] } }
  ],

  "stats": [
    { "id": "timer", "label": "Timer reading",      "unit": "s" },
    { "id": "dist",  "label": "Gate spacing d",     "unit": "m" },
    { "id": "speed", "label": "Measured speed",     "unit": "m/s", "variant": "accent" },
    { "id": "trueV", "label": "True speed",         "unit": "m/s", "variant": "info" }
  ],

  "note": "The leading edge of the card breaks the first beam to start the timer, and stops it at the second beam. Speed = distance between the gates ÷ time interval."
}
