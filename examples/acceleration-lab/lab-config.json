{
  "id": "acceleration-lab",
  "title": "Measuring the Acceleration of a Trolley",
  "subtitle": "BOX 2.1 · Interactive lab",
  "layout": "standard",
  "equipment": "kinematics",
  "canvas": { "w": 1000, "h": 470 },
  "controls": [
    {
      "id": "method",
      "label": "Method",
      "width": 260,
      "options": [
        { "value": "gate", "label": "Light gate + interrupt card" },
        { "value": "ticker", "label": "Ticker-timer" }
      ]
    }
  ],
  "params": [
    { "id": "v0", "label": "Starting speed u₀", "min": 0.1, "max": 0.8, "step": 0.05, "value": 0.3, "unit": "m/s", "decimals": 2 },
    { "id": "a", "label": "Acceleration", "min": 0.2, "max": 1.2, "step": 0.05, "value": 0.5, "unit": "m/s²", "decimals": 2 },
    { "id": "secL", "label": "Interrupt section length l", "min": 0.05, "max": 0.12, "step": 0.01, "value": 0.08,
      "unit": "m", "decimals": 2, "showIf": { "control": "method", "in": ["gate"] } }
  ],
  "stats": [
    { "id": "u", "label": "Initial u", "unit": "m/s" },
    { "id": "v", "label": "Final v", "unit": "m/s" },
    { "id": "accel", "label": "Acceleration", "unit": "m/s²", "variant": "accent" },
    { "id": "trueA", "label": "True acceleration", "unit": "m/s²", "variant": "info" }
  ],
  "note": "The card breaks the beam twice — u from the first section, v from the second."
}
